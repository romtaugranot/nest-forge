{
  "name": "nest-forge-sdk",
  "version": "1.2.0",
  "description": "Generate NestJS client SDK modules from OpenAPI specs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "nest-forge-sdk": "./dist/bin.js",
    "nest-forge": "./dist/bin.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "nestjs",
    "openapi",
    "sdk",
    "codegen",
    "orval",
    "zod",
    "axios",
    "cli",
    "code-generator",
    "client",
    "swagger",
    "typescript"
  ],
  "author": "Rom Granot <rom.granot@gmail.com>",
  "license": "MIT",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/romtaugranot/nest-forge.git"
  },
  "homepage": "https://github.com/romtaugranot/nest-forge#readme",
  "bugs": {
    "url": "https://github.com/romtaugranot/nest-forge/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@orval/core": "^8.6.2",
    "orval": "^8.6.2",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.0",
    "rimraf": "^6.0.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10.0.0",
    "axios": ">=1.0.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": false
    },
    "axios": {
      "optional": false
    },
    "zod": {
      "optional": false
    }
  }
}
